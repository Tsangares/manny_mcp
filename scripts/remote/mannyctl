#!/usr/bin/env bash
# mannyctl — thin SSH abstraction to run the manny client on ANY host  [PROTOTYPE]
#
# The orchestrator (a Claude session on the laptop) uses this to drive the manny
# client uniformly across machines. It reads scripts/remote/hosts.yaml, then runs
# every command either LOCALLY (host with local: true) or wrapped in `ssh <ssh>`.
# The client + run_routine.py always execute ON the target host so the plugin's
# local /tmp IPC files stay colocated with the client (see
# journals/REMOTE_CLIENT_ARCHITECTURE.md — this is the load-bearing constraint).
#
# Usage:
#   mannyctl list
#   mannyctl <host> provision                 # idempotent host setup (scripts/remote/provision.sh)
#   mannyctl <host> push-creds                 # USER-GATED: copy credentials.yaml (+proxies.yaml) to host
#   mannyctl <host> push-proxy                 # copy ONLY proxies.yaml (proxy token, no account creds) to host
#   mannyctl <host> start <account> [--proxy]  # thermal-guarded launch (per-account XVFB display)
#   mannyctl <host> proxy <start|stop|status>  # local SOCKS5 relay (dataimpulse residential egress)
#   mannyctl <host> stop <account>             # account-scoped stop (siblings keep running)
#   mannyctl <host> stop --all                 # ESCAPE HATCH: sweep EVERY manny client on host
#   mannyctl <host> restart <account>
#   mannyctl <host> status [account]           # host status; with an account, scope the client list
#   mannyctl <host> temp                       # quick remote package temp
#   mannyctl <host> run <routine.yaml> [args] [--proxy]  # run_routine.py ON the host (+watchdog ledger)
#   mannyctl <host> window <account> <routine> [--loops N] [--nav-backend shadow|legacy|graph] [--dry]
#                                              # ONE-COMMAND live-run ceremony (6 numbered fail-loud gates)
#   mannyctl <host> runs [run_id]              # print watchdog run ledger(s) (JSON, newest first)
#   mannyctl <host> cmd <account> <COMMAND..>  # ad-hoc: send one plugin command, print response
#   mannyctl <host> logs [account] [n]         # tail the client log on host
#   mannyctl <host> viewer [port]              # start mjpeg viewer on host, print URL
#   mannyctl <host> exec <shell...>            # escape hatch: run arbitrary cmd on host
#
# NOTE: This is a prototype skeleton. TODO markers flag spots that need a live
# host to validate. It intentionally never prints credentials/tokens.
#
# ---- `window`: the mechanized live-run ceremony -----------------------------
# `mannyctl <host> window <account> <routine> [--loops N] [--nav-backend X] [--dry]`
# replaces the ~10-minute by-hand checklist five supervised tutorial attempts
# converged on (journals/2026-07-19_tutorial_attempt{3,3b,4,5}) with ONE
# invocation that runs six numbered gates and HARD-FAILS LOUDLY at the first
# violated one (never auto-kills, never auto-fixes — it refuses and tells you):
#   GATE 1 predecessor-dead : no java client / run_routine.py / watchdog.py is
#                             already driving <account> on the host (ps + jar-glob
#                             + /proc environ; the bracket-trick avoids the
#                             pgrep -f self-match trap from attempt #5).
#   GATE 2 credentials      : local fix_credentials_defaults.sh sanitize; assert
#                             the alias exists AND default: is not a BANNED alias
#                             (new/newbakshesh); rsync creds to host (600).
#   GATE 3 display          : <account> MUST have an explicit account_displays
#                             mapping in hosts.yaml (never the :2 physical-desktop
#                             fallback that hijacked the real desktop in #3b/#4).
#   GATE 4 provision        : FIRST assert the build-path jar == the reviewed sha in
#                             scripts/remote/jar_pin.yaml (fail-closed; --accept-new-jar
#                             <prefix> to adopt+repin), THEN git-stash the parked
#                             humanize paths, provision, pop, VERIFY the pop restored
#                             them; then assert on-host: jar sha pin matches the host
#                             jar, routine.py has 0 humanize refs, the routine exists.
#   GATE 5 launch           : client_remote.sh start on the hosts.yaml display with
#                             NAV_BACKEND (default shadow), then a DEFECT-32 login
#                             gate (abort on >3 world-hops / terminal-ban latch);
#                             confirm LOGGED_IN + real location. NEVER touches the
#                             mcptools display-pool allocator — display is hosts.yaml only.
#   GATE 6 run              : run_routine.py detached (as `run`) + watchdog ledger.
# --dry runs the read-only checks (gates 1-4) and prints what 5-6 WOULD do,
# launching nothing. Every gate prints one WINDOW_GATE PASS/FAIL line and the run
# ends with a machine-greppable WINDOW_RESULT summary block.

set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
HOSTS_YAML="${MANNY_HOSTS_YAML:-$SCRIPT_DIR/hosts.yaml}"

# Optional SOCKS relay port override, forwarded when --proxy is used on
# start/run/proxy. Unset => the host scripts use their default (1080).
PROXY_PORT="${MANNY_SOCKS_PORT:-}"

# Prefer the repo venv python (has pyyaml); fall back to system python3.
PYBIN="$REPO_DIR/venv/bin/python"
[ -x "$PYBIN" ] || PYBIN="python3"

die() { echo "mannyctl: $*" >&2; exit 1; }

# hostfield <host> <field> — print one field from hosts.yaml (empty if unset).
hostfield() {
  "$PYBIN" - "$HOSTS_YAML" "$1" "$2" <<'PY'
import sys, yaml
path, host, field = sys.argv[1], sys.argv[2], sys.argv[3]
with open(path) as f:
    data = yaml.safe_load(f) or {}
h = (data.get("hosts") or {}).get(host)
if h is None:
    sys.exit(3)
v = h.get(field, "")
if v is None:
    v = ""
print(v)
PY
}

# host_account_display <host> <account> — per-account XVFB display from
# hosts.yaml (hosts.<host>.account_displays.<account>). Empty if unset so the
# caller can fall back to the host-level display. This is the lane-2 knob: each
# account renders on its own Xvfb so two clients never share one framebuffer.
host_account_display() {
  "$PYBIN" - "$HOSTS_YAML" "$1" "$2" <<'PY'
import sys, yaml
path, host, acct = sys.argv[1], sys.argv[2], sys.argv[3]
with open(path) as f:
    data = yaml.safe_load(f) or {}
h = (data.get("hosts") or {}).get(host) or {}
m = h.get("account_displays") or {}
v = m.get(acct, "")
print(v if v is not None else "")
PY
}

# lane_port <account> — the account's assigned dataimpulse gateway port from
# hosts.yaml top-level `proxy_lanes.<account>` (port-per-lane sticky model).
# Empty if the account has no lane (=> shared default lane :10000). Global, not
# per-host: an account gets the same residential lane on whatever host runs it.
lane_port() {
  "$PYBIN" - "$HOSTS_YAML" "$1" <<'PY'
import sys, yaml
path, acct = sys.argv[1], sys.argv[2]
with open(path) as f:
    data = yaml.safe_load(f) or {}
m = data.get("proxy_lanes") or {}
v = m.get(acct, "")
print(v if v is not None else "")
PY
}

# resolve_display <account> — the account's mapped display, else the host
# default ($H_DISPLAY). Requires load_host to have run.
resolve_display() {
  local acct="${1:-}" d=""
  [ -n "$acct" ] && d="$(host_account_display "$HOST" "$acct")"
  if [ -n "$d" ] && [ "$d" != "None" ]; then echo "$d"; else echo "$H_DISPLAY"; fi
}

list_hosts() {
  "$PYBIN" - "$HOSTS_YAML" <<'PY'
import sys, yaml
with open(sys.argv[1]) as f:
    data = yaml.safe_load(f) or {}
hosts = data.get("hosts") or {}
w = max((len(n) for n in hosts), default=4)
print(f"{'HOST'.ljust(w)}  KIND    SSH                        EGRESS")
for name, h in hosts.items():
    kind = "local" if h.get("local") else "remote"
    ssh = str(h.get("ssh") or "-")
    egr = str(h.get("egress") or "")
    print(f"{name.ljust(w)}  {kind:6}  {ssh:26} {egr}")
PY
}

# Load host fields into globals. Exits if host unknown.
load_host() {
  HOST="$1"
  H_LOCAL="$(hostfield "$HOST" local)" || die "unknown host '$HOST' (see: mannyctl list)"
  H_SSH="$(hostfield "$HOST" ssh)"
  H_JDK="$(hostfield "$HOST" jdk)"
  H_DISPLAY="$(hostfield "$HOST" display)"
  H_STAGING="$(hostfield "$HOST" staging_dir)"
  H_LIBS="$(hostfield "$HOST" runelite_libs)"
  H_VENVPY="$(hostfield "$HOST" venv_python)"
  H_REFUSE="$(hostfield "$HOST" temp_refuse_c)"
  H_WARN="$(hostfield "$HOST" temp_warn_c)"
  H_VHOST="$(hostfield "$HOST" viewer_host)"
  H_VPORT="$(hostfield "$HOST" viewer_port)"
  # force_proxy: MANDATORY-proxy host. When true, EVERY client launch on this host
  # egresses via the local SOCKS5 relay (MANNY_PROXY=1 is forced on, --proxy or
  # not). client_remote.sh then fails CLOSED if the relay is down — so a host
  # whose bare IP is ban-poison (datacenter) can never leak it. Used for mat.
  H_FORCE_PROXY="$(hostfield "$HOST" force_proxy)"
}

is_local() { [ "$H_LOCAL" = "True" ] || [ "$H_LOCAL" = "true" ]; }

# run_on_host <shell-command-string> — the ONE abstraction. Local hosts run the
# string in a login shell directly; remote hosts get it wrapped in ssh. The
# command string is passed verbatim to `bash -lc` on the far side.
run_on_host() {
  local cmd="$1"
  if is_local; then
    bash -lc "$cmd"
  else
    [ -n "$H_SSH" ] && [ "$H_SSH" != "None" ] || die "host '$HOST' is not local but has no ssh: set"
    # -o BatchMode=yes: fail fast instead of hanging on a password prompt.
    # Wrap in `bash -lc` (mirrors the local branch): the remote login shell may be
    # fish (diort), which rejects the bash env-prefix / printf %q / ${var@Q}
    # ANSI-C quoting these commands rely on. printf %q makes it survive the fish hop.
    ssh -o BatchMode=yes "$H_SSH" "bash -lc $(printf %q "$cmd")"
  fi
}

# client_env_prefix [display] — env assignments that parameterize
# client_remote.sh for this host. XVFB_DISPLAY defaults to the host display but
# callers pass a per-account display (resolve_display) so lane-2 clients render
# on separate Xvfb screens.
client_env_prefix() {
  local disp="${1:-$H_DISPLAY}"
  printf 'REPO_DIR=%q RUNELITE_LIBS=%q JAVA_BIN=%q XVFB_DISPLAY=%q TEMP_REFUSE_C=%q TEMP_WARN_C=%q' \
    "$H_STAGING" "$H_LIBS" "$H_JDK" "$disp" "$H_REFUSE" "$H_WARN"
  # force_proxy hosts (e.g. mat, datacenter IP) always proxy: turn PROXY_FLAG on
  # here so start/run egress via the relay even without an explicit --proxy. The
  # fail-closed launch guard in client_remote.sh then prevents any home/host-IP leak.
  if [ "$H_FORCE_PROXY" = "True" ] || [ "$H_FORCE_PROXY" = "true" ]; then PROXY_FLAG=1; fi
  # Opt-in proxy: --proxy on start/run sets PROXY_FLAG so the client egresses via
  # the local SOCKS5 relay. Appended only when requested — default OFF, so
  # status/stop/temp (which never set PROXY_FLAG) are untouched.
  if [ -n "${PROXY_FLAG:-}" ]; then
    printf ' MANNY_PROXY=1'
    # Port-per-lane: LANE_UPSTREAM_PORT (set by do_start/do_run from proxy_lanes)
    # pins BOTH the local relay/JVM port and the upstream gateway port to the
    # account's assigned lane, so concurrent clients get distinct stable exits.
    # Falls back to PROXY_PORT (MANNY_SOCKS_PORT override) or the default lane.
    local sp="${LANE_UPSTREAM_PORT:-${PROXY_PORT:-}}"
    [ -n "$sp" ] && printf ' MANNY_SOCKS_PORT=%q' "$sp"
    [ -n "${LANE_UPSTREAM_PORT:-}" ] && printf ' MANNY_UPSTREAM_PORT=%q' "$LANE_UPSTREAM_PORT"
  fi
}

client_remote_cmd() {
  # client_remote_cmd <display> <client_remote.sh args...>
  local disp="$1"; shift
  echo "cd $(printf %q "$H_STAGING") && $(client_env_prefix "$disp") ./scripts/remote/client_remote.sh $*"
}

# proxy_remote_cmd <start|stop|status> — run proxy_relay.sh ON the host. Forwards
# REPO_DIR (for the host venv python) and an optional MANNY_SOCKS_PORT override.
proxy_remote_cmd() {
  local action="$1"
  local envp; envp="REPO_DIR=$(printf %q "$H_STAGING")"
  [ -n "${PROXY_PORT:-}" ] && envp="$envp MANNY_SOCKS_PORT=$(printf %q "$PROXY_PORT")"
  echo "cd $(printf %q "$H_STAGING") && $envp ./scripts/remote/proxy_relay.sh $(printf %q "$action")"
}

# ---- subcommands ----------------------------------------------------------

# do_start [account] [--proxy] — --proxy (any position) sets PROXY_FLAG so the
# client_env_prefix threads MANNY_PROXY=1 into the host launch env.
do_start() {
  local acct="" d
  for a in "$@"; do
    case "$a" in
      --proxy) PROXY_FLAG=1 ;;
      *) [ -z "$acct" ] && acct="$a" ;;
    esac
  done
  [ -n "$acct" ] || die "start needs an account"
  d="$(resolve_display "$acct")"
  LANE_UPSTREAM_PORT="$(lane_port "$acct")"
  run_on_host "$(client_remote_cmd "$d" start "$acct")"
}
do_restart() { local d; d="$(resolve_display "$1")"; run_on_host "$(client_remote_cmd "$d" restart "$1")"; }

# do_proxy <start|stop|status> — manage the host's local SOCKS5 relay directly.
do_proxy() {
  local action="${1:-}"
  case "$action" in
    start|stop|status) run_on_host "$(proxy_remote_cmd "$action")" ;;
    "") die "proxy needs: start|stop|status" ;;
    *)  die "unknown proxy action '$action' (start|stop|status)" ;;
  esac
}

# do_stop <account> | --all — scoped by default; --all is the blanket sweep.
do_stop() {
  local arg="${1:-}"
  case "$arg" in
    --all|-a) run_on_host "$(client_remote_cmd "$H_DISPLAY" stop --all)" ;;
    "")       die "stop needs an account (e.g. mannyctl $HOST stop blast) or --all to sweep every client" ;;
    *)        local d; d="$(resolve_display "$arg")"; run_on_host "$(client_remote_cmd "$d" stop "$arg")" ;;
  esac
}

# do_status [account] — optional account scopes the client listing.
do_status() {
  local acct="${1:-}" d; d="$(resolve_display "$acct")"
  run_on_host "$(client_remote_cmd "$d" status "$acct")"
}

do_temp() {
  # Reuse client_remote.sh's status thermal block via a tiny inline read.
  run_on_host "cd $(printf %q "$H_STAGING") && $(client_env_prefix "$H_DISPLAY") ./scripts/remote/client_remote.sh status | sed -n '/thermal/,\$p'"
}

do_run() {
  # run_routine.py ON the host (IPC stays local to the client). All args after
  # the routine path are forwarded (--loops, --account, ...).
  #
  # DEFAULT: launch DETACHED (setsid, </dev/null, stdout+stderr -> host log) so
  # the grind survives an SSH disconnect (no SIGHUP kills a long unattended run).
  # Use --attach (alias --foreground) to keep the old blocking behavior instead.
  local attach=""
  case "${1:-}" in
    --attach|--foreground) attach=1; shift ;;
  esac

  # --proxy (any position): forward the proxy env to the host run env and strip
  # the flag from the run_routine.py args. Default OFF (proxy_env empty).
  local proxy_env="" filtered=()
  for a in "$@"; do
    case "$a" in
      --proxy) PROXY_FLAG=1 ;;
      *) filtered+=("$a") ;;
    esac
  done
  if [ "${#filtered[@]}" -gt 0 ]; then set -- "${filtered[@]}"; else set --; fi

  [ $# -ge 1 ] || die "run needs a routine path, e.g.: mannyctl $HOST run routines/combat/x.yaml --account new"

  # Derive a log filename: prefer the account (--account <id>), else the routine
  # basename. Purely for a stable, discoverable host-side log path.
  local routine="$1"
  local acct="" prev=""
  for tok in "$@"; do
    [ "$prev" = "--account" ] && { acct="$tok"; break; }
    prev="$tok"
  done

  # Proxy env (built AFTER acct is known so port-per-lane can resolve the lane).
  if [ -n "${PROXY_FLAG:-}" ]; then
    proxy_env="MANNY_PROXY=1"
    local lane=""
    [ -n "$acct" ] && lane="$(lane_port "$acct")"
    if [ -n "$lane" ]; then
      # port-per-lane: pin local relay/JVM port AND upstream gateway port.
      proxy_env="$proxy_env MANNY_SOCKS_PORT=$(printf %q "$lane") MANNY_UPSTREAM_PORT=$(printf %q "$lane")"
    elif [ -n "${PROXY_PORT:-}" ]; then
      proxy_env="$proxy_env MANNY_SOCKS_PORT=$(printf %q "$PROXY_PORT")"
    fi
  fi
  local logname
  if [ -n "$acct" ]; then
    logname="manny_run_${acct}"
  else
    local base; base="$(basename "$routine")"; base="${base%.yaml}"
    logname="manny_routine_${base}"
  fi
  # Sanitize to a safe filename (alnum, dot, dash, underscore).
  logname="$(printf '%s' "$logname" | tr -c 'A-Za-z0-9._-' '_')"
  local log="/tmp/${logname}.log"

  local args; args="$(printf '%q ' "$@")"

  if [ -n "$attach" ]; then
    run_on_host "cd $(printf %q "$H_STAGING") && ${proxy_env:+$proxy_env }PYTHONUNBUFFERED=1 $(printf %q "$H_VENVPY") run_routine.py $args"
    return
  fi

  # A run_id ties the detached grind to its watchdog ledger. Timestamp-ish +
  # account/routine so it's human-scannable and unique per launch.
  local run_id; run_id="$(date -u +%Y%m%dT%H%M%SZ)"
  if [ -n "$acct" ]; then run_id="${run_id}_${acct}"
  else local rb; rb="$(basename "$routine")"; run_id="${run_id}_${rb%.yaml}"; fi
  run_id="$(printf '%s' "$run_id" | tr -c 'A-Za-z0-9._-' '_')"
  local ledger="/tmp/manny_runs/${run_id}.json"
  local wd_acct="${acct:-new}"                 # watchdog needs an account for state/log paths
  local wd_log="/tmp/manny_watchdog_${run_id}.log"

  echo "launching routine DETACHED on $HOST (survives SSH disconnect) ..."
  # setsid detaches into a new session; </dev/null + >log 2>&1 sever the tty so a
  # dropped SSH connection can't SIGHUP it. We capture the PID, give it a moment,
  # then confirm it's still alive so the launch confirmation stays meaningful.
  # NOTE: this reuses do_viewer's proven detach construction (setsid + disown).
  # On successful launch we ALSO setsid-detach watchdog.py against the run pid so
  # an unattended grind gets a thermal/freeze/crash guardian + a JSON run ledger
  # at $ledger. The watchdog runs from the repo root (cwd from the cd above) so it
  # can import mcptools.tools.monitoring.CRASH_PATTERNS; --temp-refuse mirrors this
  # host's hosts.yaml threshold. \$pid is expanded on the FAR side (same session).
  run_on_host "cd $(printf %q "$H_STAGING") || exit 1; ${proxy_env:+$proxy_env }PYTHONUNBUFFERED=1 setsid $(printf %q "$H_VENVPY") run_routine.py $args </dev/null >$(printf %q "$log") 2>&1 & pid=\$!; disown; sleep 1; if kill -0 \$pid 2>/dev/null; then setsid $(printf %q "$H_VENVPY") scripts/remote/watchdog.py --run-id $(printf %q "$run_id") --account $(printf %q "$wd_acct") --routine $(printf %q "$routine") --run-pid \$pid --temp-refuse $(printf %q "${H_REFUSE:-88}") </dev/null >$(printf %q "$wd_log") 2>&1 & wpid=\$!; disown; echo \"MANNY_RUN_STARTED pid=\$pid\"; echo \"MANNY_WATCHDOG_STARTED wpid=\$wpid run_id=$(printf %q "$run_id")\"; else echo \"MANNY_RUN_FAILED (process exited immediately; see log)\" >&2; echo '--- tail of log ---' >&2; tail -n 20 $(printf %q "$log") >&2 || true; exit 1; fi"
  local rc=$?
  if [ $rc -eq 0 ]; then
    echo "routine detached on $HOST. log: $log"
    echo "MANNY_RUN_ID $run_id"
    echo "MANNY_RUN_LEDGER $ledger"
    echo "follow it with:"
    echo "  mannyctl $HOST exec tail -f $log"
    echo "  mannyctl $HOST logs        # client log"
    echo "  mannyctl $HOST status      # thermal + client status"
    echo "  mannyctl $HOST runs $run_id   # the watchdog run ledger (JSON)"
  fi
  return $rc
}

do_runs() {
  # Print watchdog run ledgers from /tmp/manny_runs on the host. No arg => list
  # all records, newest first; one arg => that run_id's record. cat'd over ssh so
  # the caller (or an LLM driver) can parse the raw JSON.
  local rid="${1:-}"
  if [ -n "$rid" ]; then
    run_on_host "f=/tmp/manny_runs/$(printf %q "$rid").json; if [ -f \"\$f\" ]; then cat \"\$f\"; else echo \"no run record: \$f\" >&2; exit 1; fi"
  else
    run_on_host 'd=/tmp/manny_runs; if ! ls "$d"/*.json >/dev/null 2>&1; then echo "(no run records in $d)"; exit 0; fi; for f in $(ls -1t "$d"/*.json 2>/dev/null); do echo "=== $f ==="; cat "$f"; echo; done'
  fi
}

do_cmd() {
  # Ad-hoc single command via the canonical transport, executed on the host so
  # it reads/writes the host's local /tmp IPC files. Prints the plugin response.
  [ $# -ge 2 ] || die "cmd needs: <account> <COMMAND...>"
  local acct="$1"; shift
  local command="$*"
  # Uses transport.send_command_sync — same path as run_routine.py, rid-correlated.
  run_on_host "cd $(printf %q "$H_STAGING") && $(printf %q "$H_VENVPY") -c $(printf %q "
import json
from mcptools import transport
r = transport.send_command_sync(${command@Q}, account_id=${acct@Q}, await_response=True, timeout=10.0)
print(json.dumps(r, indent=2))
")"
  # VERIFIED(live, diort/fish 4.6, 2026-07-18): ${var@Q} quoting survives the hop.
  # ${command@Q}/${acct@Q} expand locally (bash) to correct quoting; the inner
  # printf %q collapses newlines to $'\n' so $cmd has NO literal newlines, hence
  # the outer run_on_host `printf %q "$cmd"` stays fish-parseable and bash -lc
  # reconstructs it. Round-trips 'GOTO 3235 3295 0' / 'KILL_LOOP Chicken 200' intact.
}

do_logs() {
  local acct="${1:-new}"; local n="${2:-40}"
  local log="/tmp/runelite.log"
  [ "$acct" = "new" ] || log="/tmp/runelite_${acct}.log"
  run_on_host "tail -n $(printf %q "$n") $(printf %q "$log")"
}

do_viewer() {
  local port="${1:-$H_VPORT}"
  echo "starting mjpeg viewer on $HOST display $H_DISPLAY port $port ..."
  # Detached so it keeps running after the ssh session closes.
  run_on_host "cd $(printf %q "$H_STAGING") && MJPEG_DISPLAY=$(printf %q "$H_DISPLAY") MJPEG_PORT=$(printf %q "$port") MJPEG_FPS=1.5 setsid $(printf %q "$H_VENVPY") scripts/mjpeg_viewer.py >/tmp/mjpeg_viewer.log 2>&1 </dev/null & disown; echo started"
  echo "view: http://${H_VHOST}:${port}/view?display=${H_DISPLAY}"
}

do_provision() {
  # Runs scripts/remote/provision.sh. For a REMOTE host the very first run is a
  # chicken-and-egg (the repo isn't there yet), so provision.sh is designed to
  # be COPIED then run: we scp just that one script, then execute it, and it
  # rsyncs the rest. For a local host it's already present.
  if is_local; then
    bash "$SCRIPT_DIR/provision.sh" "$HOST"
  else
    [ -n "$H_SSH" ] && [ "$H_SSH" != "None" ] || die "remote host '$HOST' has no ssh:"
    echo "provisioning remote host '$HOST' ($H_SSH) ..."
    # provision.sh runs FROM the orchestrator and pushes to the host; it only
    # needs hosts.yaml + ssh reachability. Just invoke it locally with the host.
    MANNY_HOSTS_YAML="$HOSTS_YAML" bash "$SCRIPT_DIR/provision.sh" "$HOST"
  fi
}

do_push_creds() {
  # USER-GATED. Copies ~/.manny/credentials.yaml (account tokens) AND, if present,
  # ~/.manny/proxies.yaml (dataimpulse proxy token — Bolt-immune, needed by the
  # SOCKS5 relay) to the host with strict perms. Never rsync -a the whole ~/.manny
  # (it holds training_data/). Never logged/printed. See the arch doc security note.
  if is_local; then die "'$HOST' is local — creds already here"; fi
  local src="$HOME/.manny/credentials.yaml"
  [ -f "$src" ] || die "no $src on the orchestrator"

  # finding #5: a Bolt re-import silently resets `default:` to a BANNED alias
  # (new/newbakshesh). Sanitize the LOCAL creds before pushing so a banned
  # default can never be propagated to a host and then auto-started unattended.
  local fixcreds="$SCRIPT_DIR/../fix_credentials_defaults.sh"
  if [ -x "$fixcreds" ]; then
    "$fixcreds" || die "credential sanitize failed — refusing to push a possibly-banned default"
  else
    echo "WARN: $fixcreds not executable; skipping default-alias sanitize" >&2
  fi

  echo "About to copy live Jagex session credentials to $HOST ($H_SSH)."
  echo "This is an account-affecting step (new-device/new-IP login)."
  printf "Type 'yes' to proceed: "
  read -r ans
  [ "$ans" = "yes" ] || die "aborted (no creds copied)"
  copy_creds_to_host
  echo "credentials.yaml copied to $HOST:~/.manny/ (chmod 600). Tokens not printed."
}

# copy_creds_to_host — the NON-interactive, NON-sanitizing file-copy half of a
# creds push: scp ~/.manny/credentials.yaml (+proxies.yaml if present) to the host
# and lock perms to 600. Shared by do_push_creds (which gates + sanitizes first)
# and GATE 2 of do_window (which sanitizes + asserts first). Never rsync -a the
# whole ~/.manny (it holds training_data/); never prints tokens. Remote host only.
copy_creds_to_host() {
  local src="$HOME/.manny/credentials.yaml"
  [ -f "$src" ] || die "no $src on the orchestrator"
  run_on_host "mkdir -p ~/.manny && chmod 700 ~/.manny"
  scp -q "$src" "$H_SSH:.manny/credentials.yaml" || die "scp credentials.yaml failed"
  run_on_host "chmod 600 ~/.manny/credentials.yaml"
  local psrc="$HOME/.manny/proxies.yaml"
  if [ -f "$psrc" ]; then
    scp -q "$psrc" "$H_SSH:.manny/proxies.yaml" || die "proxies.yaml scp failed"
    run_on_host "chmod 600 ~/.manny/proxies.yaml"
  fi
}

# do_push_proxy — copy ONLY ~/.manny/proxies.yaml (the dataimpulse proxy token,
# NOT account creds). Non-gated: it carries no Jagex session, so it triggers no
# new-device login. Needed on any host before `mannyctl <host> proxy start`.
do_push_proxy() {
  if is_local; then die "'$HOST' is local — proxies.yaml already here"; fi
  local psrc="$HOME/.manny/proxies.yaml"
  [ -f "$psrc" ] || die "no $psrc on the orchestrator"
  run_on_host "mkdir -p ~/.manny && chmod 700 ~/.manny"
  scp -q "$psrc" "$H_SSH:.manny/proxies.yaml" || die "proxies.yaml scp failed"
  run_on_host "chmod 600 ~/.manny/proxies.yaml"
  echo "proxies.yaml copied to $HOST:~/.manny/ (chmod 600). Proxy token not printed."
}

do_exec() { run_on_host "$*"; }

# ---- window: the mechanized live-run ceremony -----------------------------
# Six numbered fail-loud gates. Each prints exactly one `WINDOW_GATE <n> <name>
# PASS|FAIL|DRY|SKIP: <detail>` line; a violated gate aborts the whole run and
# prints the machine-greppable WINDOW_RESULT summary. Composition, not a rewrite:
# GATE 4 delegates to do_provision, GATE 6 to do_run, GATE 2 to
# fix_credentials_defaults.sh + copy_creds_to_host — window only adds the gating.
WIN_G=()            # WIN_G[n] = PASS|FAIL|DRY|SKIP for gate n
WIN_HOST=""; WIN_ACCT=""; WIN_ROUTINE=""; WIN_NAV=""; WIN_DRY=""

BANNED_ALIASES="new newbakshesh"   # never auto-start here (ban-detection gate only)

win_gate() {  # <n> <name> <status> <detail...>
  local n="$1" name="$2" status="$3"; shift 3
  WIN_G[$n]="$status"
  printf 'WINDOW_GATE %s %-16s %s: %s\n' "$n" "$name" "$status" "$*"
}

win_summary() {  # <overall>
  local overall="$1" n
  echo "=== WINDOW SUMMARY (host=$WIN_HOST account=$WIN_ACCT routine=$WIN_ROUTINE nav=$WIN_NAV dry=${WIN_DRY:-0}) ==="
  local line="WINDOW_RESULT"
  for n in 1 2 3 4 5 6; do line="$line gate${n}=${WIN_G[$n]:-SKIP}"; done
  echo "$line"
  echo "WINDOW_RESULT overall=$overall"
}

# win_abort <gate_n> <name> <detail...> — print the FAIL line, mark this gate
# FAIL + all later gates SKIP, emit the summary, and exit loudly (never proceeds).
win_abort() {
  local n="$1" name="$2"; shift 2
  win_gate "$n" "$name" FAIL "$*"
  local i; for i in 1 2 3 4 5 6; do [ "$i" -gt "$n" ] && WIN_G[$i]="SKIP"; done
  win_summary FAIL
  exit 1
}

do_window() {
  # Parse: <account> <routine> [--loops N] [--nav-backend X] [--dry]
  local acct="" routine="" loops="" nav="shadow" dry="" accept_jar="" pos=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry|--dry-run) dry=1; shift ;;
      --loops) loops="${2:?--loops needs N}"; shift 2 ;;
      --nav-backend) nav="${2:?--nav-backend needs shadow|legacy|graph}"; shift 2 ;;
      --loops=*) loops="${1#--loops=}"; shift ;;
      --nav-backend=*) nav="${1#--nav-backend=}"; shift ;;
      --accept-new-jar) accept_jar="${2:?--accept-new-jar needs a sha-prefix}"; shift 2 ;;
      --accept-new-jar=*) accept_jar="${1#--accept-new-jar=}"; shift ;;
      -h|--help) echo "usage: mannyctl $HOST window <account> <routine> [--loops N] [--nav-backend shadow|legacy|graph] [--accept-new-jar <sha-prefix>] [--dry]"; return 0 ;;
      --*) die "window: unknown flag '$1'" ;;
      *) pos+=("$1"); shift ;;
    esac
  done
  acct="${pos[0]:-}"; routine="${pos[1]:-}"
  [ -n "$acct" ]    || die "window needs an <account> (e.g. mannyctl $HOST window punitpun routines/tutorial_island/00_master.yaml)"
  [ -n "$routine" ] || die "window needs a <routine> path (e.g. routines/tutorial_island/00_master.yaml)"
  case "$acct" in *[!A-Za-z0-9_]*) die "window: account '$acct' has unexpected characters (expect [A-Za-z0-9_])";; esac
  case "$nav" in shadow|legacy|graph) ;; *) die "window: --nav-backend must be shadow|legacy|graph (got '$nav')";; esac
  if [ -n "$loops" ]; then case "$loops" in *[!0-9]*) die "window: --loops must be a positive integer (got '$loops')";; esac; fi

  WIN_HOST="$HOST"; WIN_ACCT="$acct"; WIN_ROUTINE="$routine"; WIN_NAV="$nav"; WIN_DRY="$dry"

  echo "=== mannyctl window: $acct -> $routine on $HOST (nav=$nav${loops:+ loops=$loops}${dry:+ DRY-RUN}) ==="

  # Bootstrap the on-host gate helpers so GATE 1 (predecessor) can run BEFORE the
  # GATE 4 provision. Mirrors provision.sh's own copy-then-run bootstrap. Benign:
  # deploys ONLY the read-only checking tools (window_checks.py / window_login_gate.py)
  # — no creds, no client/game state. Skipped for a local host (already present).
  if ! is_local; then
    run_on_host "mkdir -p $(printf %q "$H_STAGING/scripts/remote")" \
      && scp -q "$SCRIPT_DIR/window_checks.py" "$SCRIPT_DIR/window_login_gate.py" "$H_SSH:$H_STAGING/scripts/remote/" \
      || die "window: failed to deploy gate helpers to $HOST (ssh/scp reachable?)"
  fi

  # ---- GATE 1: predecessor-dead (read-only; runs in dry + real) ------------
  # Delegated to scripts/remote/window_checks.py (predecessor) which scans /proc
  # for a java client (comm=java + *shaded.jar + MANNY_ACCOUNT_ID=acct) and for a
  # python run_routine.py/watchdog.py already driving --account acct. Gating on
  # comm=java|python* means the check can NEVER self-match — the attempt-#5
  # pgrep -f trap is structurally impossible. Refuses if alive; NEVER auto-kills.
  # A host that lacks the helper (never provisioned) definitionally has no manny
  # predecessor, so an absent helper is treated as CLEAR.
  local pred_out pred_rc
  pred_out="$(run_on_host "if [ -f $(printf %q "$H_STAGING/scripts/remote/window_checks.py") ]; then cd $(printf %q "$H_STAGING") && $(printf %q "$H_VENVPY") scripts/remote/window_checks.py predecessor --account $(printf %q "$acct"); else echo PREDECESSOR_CLEAR_NOHOSTREPO; fi")"; pred_rc=$?
  case "$pred_out" in
    PREDECESSOR_ALIVE*)
      win_abort 1 predecessor-dead "${pred_out#PREDECESSOR_ALIVE } is still driving '$acct' on $HOST — refusing (stop it yourself: mannyctl $HOST stop $acct; never auto-killed here)" ;;
    PREDECESSOR_CLEAR_NOHOSTREPO)
      win_gate 1 predecessor-dead PASS "host has no manny_mcp checkout yet — no predecessor possible" ;;
    PREDECESSOR_CLEAR)
      win_gate 1 predecessor-dead PASS "no java client / run_routine.py / watchdog.py driving '$acct' on $HOST" ;;
    *)
      win_abort 1 predecessor-dead "could not verify predecessor state on $HOST (rc=$pred_rc out='$pred_out') — refusing to proceed blind" ;;
  esac

  # ---- GATE 2: credentials -------------------------------------------------
  # Local sanitize (idempotent; only ever touches the LOCAL creds file) so a Bolt
  # re-import can't leave default: pointed at a BANNED alias, then assert the alias
  # exists AND default: is safe, then (real only) rsync to host at 600.
  local creds_file="${MANNY_CREDENTIALS:-$HOME/.manny/credentials.yaml}"
  [ -f "$creds_file" ] || win_abort 2 credentials "no local creds file $creds_file"
  local fixcreds="$SCRIPT_DIR/../fix_credentials_defaults.sh"
  if [ -x "$fixcreds" ]; then
    "$fixcreds" >/dev/null 2>&1 || win_abort 2 credentials "fix_credentials_defaults.sh failed — refusing (a banned default may be unsanitized)"
  fi
  grep -qE "^  ${acct}:" "$creds_file" || win_abort 2 credentials "account alias '$acct' not present in $creds_file (import it first)"
  local cur_default; cur_default="$(sed -n 's/^default:[[:space:]]*//p' "$creds_file" | head -1)"
  local b; for b in $BANNED_ALIASES; do
    [ "$cur_default" = "$b" ] && win_abort 2 credentials "default: is the BANNED alias '$cur_default' — refusing (ban-detection gate only; fix_credentials_defaults.sh should have repaired this)"
  done
  if [ -n "$dry" ]; then
    win_gate 2 credentials PASS "alias '$acct' present, default='$cur_default' (not banned); [dry] would rsync creds to $HOST at 600"
  elif is_local; then
    win_gate 2 credentials PASS "alias '$acct' present, default='$cur_default' (not banned); host is local — creds already here"
  else
    copy_creds_to_host || win_abort 2 credentials "creds rsync to $HOST failed"
    win_gate 2 credentials PASS "alias '$acct' present, default='$cur_default' (not banned); creds synced to $HOST (600)"
  fi

  # ---- GATE 3: display (hosts.yaml explicit mapping ONLY) ------------------
  # The account MUST have an explicit account_displays entry; NEVER fall back to
  # the host `display` (:2 is llama's PHYSICAL desktop — the #3b/#4 hijack). This
  # resolved display is the ONLY display window uses (never the mcptools pool).
  local disp; disp="$(host_account_display "$HOST" "$acct")"
  if [ -z "$disp" ] || [ "$disp" = "None" ]; then
    win_abort 3 display "'$acct' has NO account_displays mapping for '$HOST' in hosts.yaml — refusing (an unmapped account would hijack the host's physical :$H_DISPLAY desktop). Add '$acct: \":N\"' under hosts.$HOST.account_displays."
  fi
  win_gate 3 display PASS "'$acct' -> display $disp (explicit hosts.yaml mapping)"

  # ---- GATE 4: provision with parked-file discipline -----------------------
  # 4.0 JAR PIN (DEFECT attempt #12): BEFORE any provision ships the jar, assert
  # the build-path *shaded.jar == the reviewed sha in scripts/remote/jar_pin.yaml.
  # Runs LOCALLY on the orchestrator (build path + pin live here), fail-closed.
  # Also enforced inside provision.sh, but surfaced here as a numbered gate so a
  # surprise rebuild aborts the ceremony with both shas printed, not a buried log.
  # --accept-new-jar <prefix> adopts the build jar (rewrites the pin + logs it),
  # after which provision.sh's own copy of this gate passes cleanly.
  local jp_libs="$REPO_DIR/../runelite/runelite-client/build/libs"
  local jp_out jp_rc
  jp_out="$("$PYBIN" "$SCRIPT_DIR/window_checks.py" jar-pin --libs "$jp_libs" --pin "$SCRIPT_DIR/jar_pin.yaml" ${accept_jar:+--accept-new-jar "$accept_jar"})"; jp_rc=$?
  case "$jp_out" in
    JARPIN_OK*)       ;;
    JARPIN_ACCEPTED*) echo "-- GATE 4: jar pin UPDATED via --accept-new-jar ($jp_out) --" ;;
    *) [ "$jp_rc" -eq 0 ] || win_abort 4 provision "JAR PIN mismatch — build-path jar != scripts/remote/jar_pin.yaml (${jp_out#JARPIN_ERR }); resolve: (a) restore the pinned jar from backup, or (b) --accept-new-jar <sha-prefix> for a reviewed pin update. See the JAR PIN GATE block above." ;;
  esac

  # Real mode: git-stash the parked humanize paths so provision ships a CLEAN
  # routine.py (0 humanize refs) + no humanize.py, run provision, pop, VERIFY the
  # pop restored every parked path (loud fail if a stash pop is lost/conflicted).
  # Dry mode: skip the mutating stash+provision; still run the read-only on-host
  # assertions against the host's CURRENT (prior-provision) state.
  local parked=(mcptools/humanize.py tests/test_humanize.py mcptools/tools/routine.py)
  if [ -z "$dry" ]; then
    ( cd "$REPO_DIR" || exit 1
      # snapshot parked paths (sha or ABSENT) so we can verify the pop restored them
      declare -A pre=()
      local p sha
      for p in "${parked[@]}"; do
        if [ -f "$p" ]; then sha="$(sha256sum "$p" | awk '{print $1}')"; else sha="ABSENT"; fi
        pre[$p]="$sha"
      done
      local stashed=""
      if git -C "$REPO_DIR" status --porcelain -- "${parked[@]}" 2>/dev/null | grep -q .; then
        git -C "$REPO_DIR" stash push -u -m "mannyctl-window-provision-$(date -u +%Y%m%dT%H%M%SZ)" -- "${parked[@]}" >/dev/null 2>&1 \
          || { echo "WINDOW_GATE4_ERR stash-push-failed"; exit 21; }
        stashed=1
      fi
      MANNY_HOSTS_YAML="$HOSTS_YAML" bash "$SCRIPT_DIR/provision.sh" "$HOST" >/tmp/mannyctl_window_provision.log 2>&1
      local prc=$?
      if [ -n "$stashed" ]; then
        git -C "$REPO_DIR" stash pop >/dev/null 2>&1 || { echo "WINDOW_GATE4_ERR stash-pop-failed"; exit 22; }
      fi
      [ "$prc" -eq 0 ] || { echo "WINDOW_GATE4_ERR provision-rc=$prc"; exit 23; }
      # VERIFY the pop restored every parked path to its pre-stash sha
      for p in "${parked[@]}"; do
        if [ -f "$p" ]; then sha="$(sha256sum "$p" | awk '{print $1}')"; else sha="ABSENT"; fi
        [ "$sha" = "${pre[$p]}" ] || { echo "WINDOW_GATE4_ERR parked-not-restored:$p"; exit 24; }
      done
      exit 0
    )
    local grc=$?
    case "$grc" in
      0)  ;;
      21) win_abort 4 provision "git stash push of parked humanize paths FAILED — refusing to provision (would ship humanize into the client)" ;;
      22) win_abort 4 provision "git stash POP FAILED after provision — parked files may be UNRESTORED; resolve 'git stash list' manually before retrying" ;;
      23) win_abort 4 provision "provision.sh failed (see /tmp/mannyctl_window_provision.log)" ;;
      24) win_abort 4 provision "parked humanize path was NOT restored by stash pop — STOP and check the working tree/stash manually" ;;
      *)  win_abort 4 provision "provision stage failed (rc=$grc)" ;;
    esac
  fi

  # Post-provision on-host assertions (read-only; run in dry + real), delegated to
  # window_checks.py assert-provision: (a) config.yaml jar sha pin present AND ==
  # sha256 of the host *shaded.jar, (b) routine.py has ZERO humanize refs, (c) the
  # routine file exists. Single-argv invocation (no heredoc => no fish-hop hazard).
  local assert_out
  assert_out="$(run_on_host "cd $(printf %q "$H_STAGING") && $(printf %q "$H_VENVPY") scripts/remote/window_checks.py assert-provision --account $(printf %q "$acct") --staging $(printf %q "$H_STAGING") --libs $(printf %q "$H_LIBS") --routine $(printf %q "$routine")")"
  case "$assert_out" in
    ASSERT_OK*) ;;
    ASSERT_ERR*) win_abort 4 provision "on-host assertion failed: ${assert_out#ASSERT_ERR } (host may be unprovisioned; re-run without --dry, or: mannyctl $HOST provision)" ;;
    *) win_abort 4 provision "could not run on-host assertions (out='$assert_out')" ;;
  esac
  if [ -n "$dry" ]; then
    win_gate 4 provision PASS "[dry] would stash humanize paths + provision + pop+verify; on-host now: ${assert_out#ASSERT_OK }"
  else
    win_gate 4 provision PASS "provisioned (parked files stashed/popped/verified); on-host: ${assert_out#ASSERT_OK }"
  fi

  # ---- GATE 5: launch (client on the hosts.yaml display + DEFECT-32 gate) --
  if [ -n "$dry" ]; then
    win_gate 5 launch DRY "would: client_remote.sh start $acct on display $disp (NAV_BACKEND=$nav), then window_login_gate.py --account $acct --timeout 90 --max-hops 3 (abort on >3 world-hops / terminal-ban latch, require LOGGED_IN + real location) — launching NOTHING"
  else
    # Launch on the hosts.yaml-resolved display ONLY (never the mcptools display
    # pool). NAV_BACKEND threads through client_remote.sh (-Dmanny.navBackend).
    # client_remote.sh's own 30s LOGGED_IN wait is cosmetic (login can take ~40s,
    # attempt #4) so we DON'T trust its exit code — the authoritative confirmation
    # is the on-host DEFECT-32 gate polling the plugin state file.
    echo "-- GATE 5: launching client '$acct' on $disp (nav=$nav) --"
    run_on_host "cd $(printf %q "$H_STAGING") && NAV_BACKEND=$(printf %q "$nav") $(client_env_prefix "$disp") ./scripts/remote/client_remote.sh start $(printf %q "$acct")" || true
    echo "-- GATE 5: DEFECT-32 login gate (poll state file, max 90s) --"
    local login_out login_rc
    login_out="$(run_on_host "cd $(printf %q "$H_STAGING") && $(printf %q "$H_VENVPY") scripts/remote/window_login_gate.py --account $(printf %q "$acct") --timeout 90 --max-hops 3")"; login_rc=$?
    echo "$login_out"
    case "$login_rc" in
      0) win_gate 5 launch PASS "${login_out#WINDOW_LOGIN PASS: }" ;;
      3) win_abort 5 launch "SUSPECTED BAN — ${login_out#WINDOW_LOGIN BAN: } — do NOT relaunch; vision-confirm + mark the account" ;;
      4) win_abort 5 launch "DEFECT-32 world-hop — ${login_out#WINDOW_LOGIN WORLDHOP: }" ;;
      5) win_abort 5 launch "login TIMEOUT — ${login_out#WINDOW_LOGIN TIMEOUT: } (check: mannyctl $HOST logs $acct)" ;;
      *) win_abort 5 launch "login gate error rc=$login_rc: $login_out" ;;
    esac
  fi

  # ---- GATE 6: run (run_routine.py detached + watchdog, via `run`) ---------
  if [ -n "$dry" ]; then
    win_gate 6 run DRY "would: mannyctl $HOST run $routine --account $acct${loops:+ --loops $loops} (setsid-detached run_routine.py + watchdog ledger; watchdog freeze/stall/DEFECT-32 defaults + --temp-refuse ${H_REFUSE:-88}) — launching NOTHING"
    win_summary DRY-OK
    return 0
  fi
  echo "-- GATE 6: launching run_routine.py + watchdog (detached) --"
  local run_args=("$routine" --account "$acct")
  [ -n "$loops" ] && run_args+=(--loops "$loops")
  if do_run "${run_args[@]}"; then
    win_gate 6 run PASS "run_routine.py + watchdog detached on $HOST (see MANNY_RUN_ID / MANNY_RUN_LEDGER above; follow: mannyctl $HOST runs)"
    win_summary OK
    return 0
  else
    win_abort 6 run "run_routine.py failed to launch (see output above / mannyctl $HOST logs $acct)"
  fi
}

# ---- dispatch -------------------------------------------------------------

main() {
  local a1="${1:-}"
  [ -n "$a1" ] || { grep '^#' "$0" | sed -n '2,40p' | sed 's/^# \{0,1\}//'; exit 1; }

  if [ "$a1" = "list" ]; then list_hosts; exit 0; fi

  local host="$a1"; shift || true
  local sub="${1:-}"; [ -n "$sub" ] && shift || true
  load_host "$host"

  case "$sub" in
    provision)   do_provision ;;
    push-creds)  do_push_creds ;;
    push-proxy)  do_push_proxy ;;
    start)       [ $# -ge 1 ] || die "start needs an account"; do_start "$@" ;;
    proxy)       do_proxy "$@" ;;
    stop)        do_stop "$@" ;;
    restart)     [ $# -ge 1 ] || die "restart needs an account"; do_restart "$1" ;;
    status)      do_status "$@" ;;
    temp)        do_temp ;;
    run)         do_run "$@" ;;
    window)      do_window "$@" ;;
    runs)        do_runs "$@" ;;
    cmd)         do_cmd "$@" ;;
    logs)        do_logs "$@" ;;
    viewer)      do_viewer "$@" ;;
    exec)        do_exec "$@" ;;
    "")          die "no subcommand for host '$host' (try: status|start|stop|run|cmd|viewer)" ;;
    *)           die "unknown subcommand '$sub'" ;;
  esac
}
main "$@"
